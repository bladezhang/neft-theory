</table>
<p class="ltx_p" id="S3.SS3.p2.4">The parameter <math alttext="z_{*}" class="ltx_Math" display="inline" id="S3.SS3.p2.3.m1.1"><semantics id="S3.SS3.p2.3.m1.1a"><msub id="S3.SS3.p2.3.m1.1.1" xref="S3.SS3.p2.3.m1.1.1.cmml"><mi id="S3.SS3.p2.3.m1.1.1.2" xref="S3.SS3.p2.3.m1.1.1.2.cmml">z</mi><mo id="S3.SS3.p2.3.m1.1.1.3" xref="S3.SS3.p2.3.m1.1.1.3.cmml">∗</mo></msub><annotation-xml encoding="MathML-Content" id="S3.SS3.p2.3.m1.1b"><apply id="S3.SS3.p2.3.m1.1.1.cmml" xref="S3.SS3.p2.3.m1.1.1"><csymbol cd="ambiguous" id="S3.SS3.p2.3.m1.1.1.1.cmml" xref="S3.SS3.p2.3.m1.1.1">subscript</csymbol><ci id="S3.SS3.p2.3.m1.1.1.2.cmml" xref="S3.SS3.p2.3.m1.1.1.2">𝑧</ci><times id="S3.SS3.p2.3.m1.1.1.3.cmml" xref="S3.SS3.p2.3.m1.1.1.3"></times></apply></annotation-xml><annotation encoding="application/x-tex" id="S3.SS3.p2.3.m1.1c">z_{*}</annotation><annotation encoding="application/x-llamapun" id="S3.SS3.p2.3.m1.1d">italic_z start_POSTSUBSCRIPT ∗ end_POSTSUBSCRIPT</annotation></semantics></math> represents the decoupling redshift, and we use the fitting formula given in Ref. <cite class="ltx_cite ltx_citemacro_cite"><a class="ltx_ref" href="https://arxiv.org/html/2503.08236v1#bib.bib107" title="">Hu:1995en </a></cite> for it. Also, <math alttext="D_{A}(z_{*})" class="ltx_Math" display="inline" id="S3.SS3.p2.4.m2.1"><semantics id="S3.SS3.p2.4.m2.1a"><mrow id="S3.SS3.p2.4.m2.1.1" xref="S3.SS3.p2.4.m2.1.1.cmml"><msub id="S3.SS3.p2.4.m2.1.1.3" xref="S3.SS3.p2.4.m2.1.1.3.cmml"><mi id="S3.SS3.p2.4.m2.1.1.3.2" xref="S3.SS3.p2.4.m2.1.1.3.2.cmml">D</mi><mi id="S3.SS3.p2.4.m2.1.1.3.3" xref="S3.SS3.p2.4.m2.1.1.3.3.cmml">A</mi></msub><mo id="S3.SS3.p2.4.m2.1.1.2" xref="S3.SS3.p2.4.m2.1.1.2.cmml">⁢</mo><mrow id="S3.SS3.p2.4.m2.1.1.1.1" xref="S3.SS3.p2.4.m2.1.1.1.1.1.cmml"><mo id="S3.SS3.p2.4.m2.1.1.1.1.2" stretchy="false" xref="S3.SS3.p2.4.m2.1.1.1.1.1.cmml">(</mo><msub id="S3.SS3.p2.4.m2.1.1.1.1.1" xref="S3.SS3.p2.4.m2.1.1.1.1.1.cmml"><mi id="S3.SS3.p2.4.m2.1.1.1.1.1.2" xref="S3.SS3.p2.4.m2.1.1.1.1.1.2.cmml">z</mi><mo id="S3.SS3.p2.4.m2.1.1.1.1.1.3" xref="S3.SS3.p2.4.m2.1.1.1.1.1.3.cmml">∗</mo></msub><mo id="S3.SS3.p2.4.m2.1.1.1.1.3" stretchy="false" xref="S3.SS3.p2.4.m2.1.1.1.1.1.cmml">)</mo></mrow></mrow><annotation-xml encoding="MathML-Content" id="S3.SS3.p2.4.m2.1b"><apply id="S3.SS3.p2.4.m2.1.1.cmml" xref="S3.SS3.p2.4.m2.1.1"><times id="S3.SS3.p2.4.m2.1.1.2.cmml" xref="S3.SS3.p2.4.m2.1.1.2"></times><apply id="S3.SS3.p2.4.m2.1.1.3.cmml" xref="S3.SS3.p2.4.m2.1.1.3"><csymbol cd="ambiguous" id="S3.SS3.p2.4.m2.1.1.3.1.cmml" xref="S3.SS3.p2.4.m2.1.1.3">subscript</csymbol><ci id="S3.SS3.p2.4.m2.1.1.3.2.cmml" xref="S3.SS3.p2.4.m2.1.1.3.2">𝐷</ci><ci id="S3.SS3.p2.4.m2.1.1.3.3.cmml" xref="S3.SS3.p2.4.m2.1.1.3.3">𝐴</ci></apply><apply id="S3.SS3.p2.4.m2.1.1.1.1.1.cmml" xref="S3.SS3.p2.4.m2.1.1.1.1"><csymbol cd="ambiguous" id="S3.SS3.p2.4.m2.1.1.1.1.1.1.cmml" xref="S3.SS3.p2.4.m2.1.1.1.1">subscript</csymbol><ci id="S3.SS3.p2.4.m2.1.1.1.1.1.2.cmml" xref="S3.SS3.p2.4.m2.1.1.1.1.1.2">𝑧</ci><times id="S3.SS3.p2.4.m2.1.1.1.1.1.3.cmml" xref="S3.SS3.p2.4.m2.1.1.1.1.1.3"></times></apply></apply></annotation-xml><annotation encoding="application/x-tex" id="S3.SS3.p2.4.m2.1c">D_{A}(z_{*})</annotation><annotation encoding="application/x-llamapun" id="S3.SS3.p2.4.m2.1d">italic_D start_POSTSUBSCRIPT italic_A end_POSTSUBSCRIPT ( italic_z start_POSTSUBSCRIPT ∗ end_POSTSUBSCRIPT )</annotation></semantics></math> is the angular diameter distance,</p>
<table class="ltx_equation ltx_eqn_table" id="S3.E61">
