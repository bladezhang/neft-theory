<p class="ltx_p" id="S4.p1.2">The total likelihood function is related to the quantity <math alttext="\chi_{{\rm tot}}^{2}" class="ltx_Math" display="inline" id="S4.p1.1.m1.1"><semantics id="S4.p1.1.m1.1a"><msubsup id="S4.p1.1.m1.1.1" xref="S4.p1.1.m1.1.1.cmml"><mi id="S4.p1.1.m1.1.1.2.2" xref="S4.p1.1.m1.1.1.2.2.cmml">χ</mi><mi id="S4.p1.1.m1.1.1.2.3" xref="S4.p1.1.m1.1.1.2.3.cmml">tot</mi><mn id="S4.p1.1.m1.1.1.3" xref="S4.p1.1.m1.1.1.3.cmml">2</mn></msubsup><annotation-xml encoding="MathML-Content" id="S4.p1.1.m1.1b"><apply id="S4.p1.1.m1.1.1.cmml" xref="S4.p1.1.m1.1.1"><csymbol cd="ambiguous" id="S4.p1.1.m1.1.1.1.cmml" xref="S4.p1.1.m1.1.1">superscript</csymbol><apply id="S4.p1.1.m1.1.1.2.cmml" xref="S4.p1.1.m1.1.1"><csymbol cd="ambiguous" id="S4.p1.1.m1.1.1.2.1.cmml" xref="S4.p1.1.m1.1.1">subscript</csymbol><ci id="S4.p1.1.m1.1.1.2.2.cmml" xref="S4.p1.1.m1.1.1.2.2">𝜒</ci><ci id="S4.p1.1.m1.1.1.2.3.cmml" xref="S4.p1.1.m1.1.1.2.3">tot</ci></apply><cn id="S4.p1.1.m1.1.1.3.cmml" type="integer" xref="S4.p1.1.m1.1.1.3">2</cn></apply></annotation-xml><annotation encoding="application/x-tex" id="S4.p1.1.m1.1c">\chi_{{\rm tot}}^{2}</annotation><annotation encoding="application/x-llamapun" id="S4.p1.1.m1.1d">italic_χ start_POSTSUBSCRIPT roman_tot end_POSTSUBSCRIPT start_POSTSUPERSCRIPT 2 end_POSTSUPERSCRIPT</annotation></semantics></math> by <math alttext="\chi_{{\rm tot}}^{2}=-2\ln\mathcal{L}_{\mathrm{tot}}" class="ltx_Math" display="inline" id="S4.p1.2.m2.1"><semantics id="S4.p1.2.m2.1a"><mrow id="S4.p1.2.m2.1.1" xref="S4.p1.2.m2.1.1.cmml"><msubsup id="S4.p1.2.m2.1.1.2" xref="S4.p1.2.m2.1.1.2.cmml"><mi id="S4.p1.2.m2.1.1.2.2.2" xref="S4.p1.2.m2.1.1.2.2.2.cmml">χ</mi><mi id="S4.p1.2.m2.1.1.2.2.3" xref="S4.p1.2.m2.1.1.2.2.3.cmml">tot</mi><mn id="S4.p1.2.m2.1.1.2.3" xref="S4.p1.2.m2.1.1.2.3.cmml">2</mn></msubsup><mo id="S4.p1.2.m2.1.1.1" xref="S4.p1.2.m2.1.1.1.cmml">=</mo><mrow id="S4.p1.2.m2.1.1.3" xref="S4.p1.2.m2.1.1.3.cmml"><mo id="S4.p1.2.m2.1.1.3a" xref="S4.p1.2.m2.