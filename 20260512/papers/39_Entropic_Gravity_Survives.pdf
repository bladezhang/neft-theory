id="S2.E39.m2.1.1.1.1.3.2.1.cmml" xref="S2.E39.m2.1.1.1.1.3.2">subscript</csymbol><ci id="S2.E39.m2.1.1.1.1.3.2.2.cmml" xref="S2.E39.m2.1.1.1.1.3.2.2">𝜌</ci><apply id="S2.E39.m2.1.1.1.1.3.2.3.cmml" xref="S2.E39.m2.1.1.1.1.3.2.3"><times id="S2.E39.m2.1.1.1.1.3.2.3.1.cmml" xref="S2.E39.m2.1.1.1.1.3.2.3.1"></times><ci id="S2.E39.m2.1.1.1.1.3.2.3.2.cmml" xref="S2.E39.m2.1.1.1.1.3.2.3.2">𝑏</ci><cn id="S2.E39.m2.1.1.1.1.3.2.3.3.cmml" type="integer" xref="S2.E39.m2.1.1.1.1.3.2.3.3">0</cn></apply></apply><apply id="S2.E39.m2.1.1.1.1.3.3.cmml" xref="S2.E39.m2.1.1.1.1.3.3"><csymbol cd="ambiguous" id="S2.E39.m2.1.1.1.1.3.3.1.cmml" xref="S2.E39.m2.1.1.1.1.3.3">superscript</csymbol><ci id="S2.E39.m2.1.1.1.1.3.3.2.cmml" xref="S2.E39.m2.1.1.1.1.3.3.2">𝑎</ci><apply id="S2.E39.m2.1.1.1.1.3.3.3.cmml" xref="S2.E39.m2.1.1.1.1.3.3.3"><minus id="S2.E39.m2.1.1.1.1.3.3.3.1.cmml" xref="S2.E39.m2.1.1.1.1.3.3.3"></minus><cn id="S2.E39.m2.1.1.1.1.3.3.3.2.cmml" type="integer" xref="S2.E39.m2.1.1.1.1.3.3.3.2">3</cn></apply></apply></apply></apply></annotation-xml><annotation encoding="application/x-tex" id="S2.E39.m2.1c">\displaystyle=\rho_{b0}a^{-3}\,,</annotation><annotation encoding="application/x-llamapun" id="S2.E39.m2.1d">= italic_ρ start_POSTSUBSCRIPT italic_b 0 end_POSTSUBSCRIPT italic_a start_POSTSUPERSCRIPT - 3 end_POSTSUPERSCRIPT ,</annotation></semantics></math></td>
