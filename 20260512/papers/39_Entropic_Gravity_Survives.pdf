>2</cn></apply></apply></apply></annotation-xml><annotation encoding="application/x-tex" id="S2.E1.m1.1c">N=\frac{A}{\ell_{P}^{2}}\,,</annotation><annotation encoding="application/x-llamapun" id="S2.E1.m1.1d">italic_N = divide start_ARG italic_A end_ARG start_ARG roman_ℓ start_POSTSUBSCRIPT italic_P end_POSTSUBSCRIPT start_POSTSUPERSCRIPT 2 end_POSTSUPERSCRIPT end_ARG ,</annotation></semantics></math></td>
