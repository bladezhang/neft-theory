-tex" id="S3.E62.m1.3c">D_{A}(z_{*})=\frac{c}{H_{0}(1+z)}\int_{0}^{z_{*}}\frac{dz}{\tilde{H}(z)}\,.</annotation><annotation encoding="application/x-llamapun" id="S3.E62.m1.3d">italic_D start_POSTSUBSCRIPT italic_A end_POSTSUBSCRIPT ( italic_z start_POSTSUBSCRIPT ∗ end_POSTSUBSCRIPT ) = divide start_ARG italic_c end_ARG start_ARG italic_H start_POSTSUBSCRIPT 0 end_POSTSUBSCRIPT ( 1 + italic_z ) end_ARG ∫ start_POSTSUBSCRIPT 0 end_POSTSUBSCRIPT start_POSTSUPERSCRIPT italic_z start_POSTSUBSCRIPT ∗ end_POSTSUBSCRIPT end_POSTSUPERSCRIPT divide start_ARG italic_d italic_z end_ARG start_ARG over~ start_ARG italic_H end_ARG ( italic_z ) end_ARG .</annotation></semantics></math></td>
