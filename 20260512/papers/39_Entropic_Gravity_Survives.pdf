2.2.1.1.3.1.cmml" xref="S2.E36.m1.2.2.1.1.3.1"></times><apply id="S2.E36.m1.1.1.cmml" xref="S2.E36.m1.1.1"><divide id="S2.E36.m1.1.1.2.cmml" xref="S2.E36.m1.1.1"></divide><apply id="S2.E36.m1.1.1.3.cmml" xref="S2.E36.m1.1.1.3"><times id="S2.E36.m1.1.1.3.1.cmml" xref="S2.E36.m1.1.1.3.1"></times><cn id="S2.E36.m1.1.1.3.2.cmml" type="integer" xref="S2.E36.m1.1.1.3.2">8</cn><ci id="S2.E36.m1.1.1.3.3.cmml" xref="S2.E36.m1.1.1.3.3">𝜋</ci><ci id="S2.E36.m1.1.1.3.4.cmml" xref="S2.E36.m1.1.1.3.4">𝐺</ci></apply><apply id="S2.E36.m1.1.1.1.cmml" xref="S2.E36.m1.1.1.1"><times id="S2.E36.m1.1.1.1.2.cmml" xref="S2.E36.m1.1.1.1.2"></times><cn id="S2.E36.m1.1.1.1.3.cmml" type="integer" xref="S2.E36.m1.1.1.1.3">3</cn><ci id="S2.E36.m1.1.1.1.4.cmml" xref="S2.E36.m1.1.1.1.4">𝑓</ci><apply id="S2.E36.m1.1.1.1.1.cmml" xref="S2.E36.m1.1.1.1.5.2"><ci id="S2.E36.m1.1.1.1.1.1.cmml" xref="S2.E36.m1.1.1.1.1.1">¨</ci><ci id="S2.E36.m1.1.1.1.1.2.cmml" xref="S2.E36.m1.1.1.1.1.2">𝑎</ci></apply></apply></apply><ci id="S2.E36.m1.2.2.1.1.3.2.cmml" xref="S2.E36.m1.2.2.1.1.3.2">𝜌</ci></apply></apply></annotation-xml><annotation encoding="application/x-tex" id="S2.E36.m1.2c">H^{2}+\frac{k}{a^{2}}=\frac{8\pi G}{3f(\ddot{a})}\rho\,.</annotation><annotation encoding="application/x-llamapun" id="S2.E36.m1.2d">italic_H start_POSTSUPERSCRIPT 2 end_POSTSUPERSCRIPT + divide start_ARG italic_k end_ARG start_ARG italic_a start_POSTSUPERSCRIPT 2 end_POSTSUPERSCRIPT end_ARG = divide start_ARG 8 italic_π italic_G end_ARG start_ARG 3 italic_f ( over¨ start_ARG italic_a end_ARG ) end_ARG italic_ρ .</annotation></semantics></math></td>
