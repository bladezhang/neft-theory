<td class="ltx_eqn_cell ltx_eqn_center_padleft"></td>
<td class="ltx_eqn_cell ltx_align_center"><math alttext="D_{A}(z_{*})=\frac{c}{H_{0}}\frac{\mathrm{sinn}\left[H_{0}\sqrt{\left|\Omega_{%
