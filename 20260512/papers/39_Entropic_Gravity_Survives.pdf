\right)-C_{6}\,,</annotation><annotation encoding="application/x-llamapun" id="S2.E33.m2.13d">= divide start_ARG square-root start_ARG 1 - italic_k italic_r start_POSTSUPERSCRIPT 2 end_POSTSUPERSCRIPT end_ARG end_ARG start_ARG italic_r end_ARG divide start_ARG 1 end_ARG start_ARG roman_sin ( italic_θ ) end_ARG ( italic_C start_POSTSUBSCRIPT 2 end_POSTSUBSCRIPT roman_cos ( italic_ϕ ) - italic_C start_POSTSUBSCRIPT 1 end_POSTSUBSCRIPT roman_sin ( italic_ϕ ) ) + roman_cot ( italic_θ ) ( italic_C start_POSTSUBSCRIPT 4 end_POSTSUBSCRIPT roman_cos ( italic_ϕ ) + italic_C start_POSTSUBSCRIPT 5 end_POSTSUBSCRIPT roman_sin ( italic_ϕ ) ) - italic_C start_POSTSUBSCRIPT 6 end_POSTSUBSCRIPT ,</annotation></semantics></math></td>
