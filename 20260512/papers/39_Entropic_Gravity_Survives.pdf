1.cmml" xref="S2.E3.m1.2.2.1.1.1"></eq><ci id="S2.E3.m1.2.2.1.1.2.cmml" xref="S2.E3.m1.2.2.1.1.2">𝐸</ci><apply id="S2.E3.m1.2.2.1.1.3.cmml" xref="S2.E3.m1.2.2.1.1.3"><times id="S2.E3.m1.2.2.1.1.3.1.cmml" xref="S2.E3.m1.2.2.1.1.3.1"></times><apply id="S2.E3.m1.2.2.1.1.3.2.cmml" xref="S2.E3.m1.2.2.1.1.3.2"><divide id="S2.E3.m1.2.2.1.1.3.2.1.cmml" xref="S2.E3.m1.2.2.1.1.3.2"></divide><cn id="S2.E3.m1.2.2.1.1.3.2.2.cmml" type="integer" xref="S2.E3.m1.2.2.1.1.3.2.2">1</cn><cn id="S2.E3.m1.2.2.1.1.3.2.3.cmml" type="integer" xref="S2.E3.m1.2.2.1.1.3.2.3">2</cn></apply><ci id="S2.E3.m1.2.2.1.1.3.3.cmml" xref="S2.E3.m1.2.2.1.1.3.3">𝑁</ci><apply id="S2.E3.m1.2.2.1.1.3.4.cmml" xref="S2.E3.m1.2.2.1.1.3.4"><csymbol cd="ambiguous" id="S2.E3.m1.2.2.1.1.3.4.1.cmml" xref="S2.E3.m1.2.2.1.1.3.4">subscript</csymbol><ci id="S2.E3.m1.2.2.1.1.3.4.2.cmml" xref="S2.E3.m1.2.2.1.1.3.4.2">𝑘</ci><ci id="S2.E3.m1.2.2.1.1.3.4.3.cmml" xref="S2.E3.m1.2.2.1.1.3.4.3">𝐵</ci></apply><ci id="S2.E3.m1.2.2.1.1.3.5.cmml" xref="S2.E3.m1.2.2.1.1.3.5">𝑇</ci><ci id="S2.E3.m1.2.2.1.1.3.6.cmml" xref="S2.E3.m1.2.2.1.1.3.6">𝑓</ci><ci id="S2.E3.m1.1.1.cmml" xref="S2.E3.m1.1.1">𝑇</ci></apply></apply></annotation-xml><annotation encoding="application/x-tex" id="S2.E3.m1.2c">E=\frac{1}{2}Nk_{B}Tf(T)\,.</annotation><annotation encoding="application/x-llamapun" id="S2.E3.m1.2d">italic_E = divide start_ARG 1 end_ARG start_ARG 2 end_ARG italic_N italic_k start_POSTSUBSCRIPT italic_B end_POSTSUBSCRIPT italic_T italic_f ( italic_T ) .</annotation></semantics></math></td>
