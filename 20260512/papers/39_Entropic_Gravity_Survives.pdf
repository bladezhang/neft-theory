.1.cmml" xref="S3.E52.m1.3.3.1.1.3.2.3.1"><csymbol cd="ambiguous" id="S3.E52.m1.3.3.1.1.3.2.3.1.1.cmml" xref="S3.E52.m1.3.3.1.1.3.2.3.1">subscript</csymbol><log id="S3.E52.m1.3.3.1.1.3.2.3.1.2.cmml" xref="S3.E52.m1.3.3.1.1.3.2.3.1.2"></log><cn id="S3.E52.m1.3.3.1.1.3.2.3.1.3.cmml" type="integer" xref="S3.E52.m1.3.3.1.1.3.2.3.1.3">10</cn></apply><apply id="S3.E52.m1.3.3.1.1.3.2.3.2.cmml" xref="S3.E52.m1.3.3.1.1.3.2.3.2"><csymbol cd="ambiguous" id="S3.E52.m1.3.3.1.1.3.2.3.2.1.cmml" xref="S3.E52.m1.3.3.1.1.3.2.3.2">subscript</csymbol><ci id="S3.E52.m1.3.3.1.1.3.2.3.2.2.cmml" xref="S3.E52.m1.3.3.1.1.3.2.3.2.2">𝑑</ci><ci id="S3.E52.m1.3.3.1.1.3.2.3.2.3.cmml" xref="S3.E52.m1.3.3.1.1.3.2.3.2.3">𝐿</ci></apply></apply><ci id="S3.E52.m1.2.2.cmml" xref="S3.E52.m1.2.2">𝑧</ci></apply><apply id="S3.E52.m1.3.3.1.1.3.3.cmml" xref="S3.E52.m1.3.3.1.1.3.3"><csymbol cd="ambiguous" id="S3.E52.m1.3.3.1.1.3.3.1.cmml" xref="S3.E52.m1.3.3.1.1.3.3">subscript</csymbol><ci id="S3.E52.m1.3.3.1.1.3.3.2.cmml" xref="S3.E52.m1.3.3.1.1.3.3.2">𝜇</ci><cn id="S3.E52.m1.3.3.1.1.3.3.3.cmml" type="integer" xref="S3.E52.m1.3.3.1.1.3.3.3">0</cn></apply></apply></apply></annotation-xml><annotation encoding="application/x-tex" id="S3.E52.m1.3c">\mu_{\mathrm{th}}(z)=5\log_{10}d_{L}(z)-\mu_{0}\,,</annotation><annotation encoding="application/x-llamapun" id="S3.E52.m1.3d">italic_μ start_POSTSUBSCRIPT roman_th end_POSTSUBSCRIPT ( italic_z ) = 5 roman_log start_POSTSUBSCRIPT 10 end_POSTSUBSCRIPT italic_d start_POSTSUBSCRIPT italic_L end_POSTSUBSCRIPT ( italic_z ) - italic_μ start_POSTSUBSCRIPT 0 end_POSTSUBSCRIPT ,</annotation></semantics></math></td>
