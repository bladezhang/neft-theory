<p class="ltx_p" id="S3.SS4.p1.4">Then, the <math alttext="\chi^{2}" class="ltx_Math" display="inline" id="S3.SS4.p1.4.m1.1"><semantics id="S3.SS4.p1.4.m1.1a"><msup id="S3.SS4.p1.4.m1.1.1" xref="S3.SS4.p1.4.m1.1.1.cmml"><mi id="S3.SS4.p1.4.m1.1.1.2" xref="S3.SS4.p1.4.m1.1.1.2.cmml">χ</mi><mn id="S3.SS4.p1.4.m1.1.1.3" xref="S3.SS4.p1.4.m1.1.1.3.cmml">2</mn></msup><annotation-xml encoding="MathML-Content" id="S3.SS4.p1.4.m1.1b"><apply id="S3.SS4.p1.4.m1.1.1.cmml" xref="S3.SS4.p1.4.m1.1.1"><csymbol cd="ambiguous" id="S3.SS4.p1.4.m1.1.1.1.cmml" xref="S3.SS4.p1.4.m1.1.1">superscript</csymbol><ci id="S3.SS4.p1.4.m1.1.1.2.cmml" xref="S3.SS4.p1.4.m1.1.1.2">𝜒</ci><cn id="S3.SS4.p1.4.m1.1.1.3.cmml" type="integer" xref="S3.SS4.p1.4.m1.1.1.3">2</cn></apply></annotation-xml><annotation encoding="application/x-tex" id="S3.SS4.p1.4.m1.1c">\chi^{2}</annotation><annotation encoding="application/x-llamapun" id="S3.SS4.p1.4.m1.1d">italic_χ start_POSTSUPERSCRIPT 2 end_POSTSUPERSCRIPT</annotation></semantics></math> term is just</p>
