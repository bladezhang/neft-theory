<p class="ltx_p" id="S2.p19.4">where <math alttext="\tilde{H}\equiv H/H_{0}" class="ltx_Math" display="inline" id="S2.p19.4.m1.1"><semantics id="S2.p19.4.m1.1a"><mrow id="S2.p19.4.m1.1.1" xref="S2.p19.4.m1.1.1.cmml"><mover accent="true" id="S2.p19.4.m1.1.1.2" xref="S2.p19.4.m1.1.1.2.cmml"><mi id="S2.p19.4.m1.1.1.2.2" xref="S2.p19.4.m1.1.1.2.2.cmml">H</mi><mo id="S2.p19.4.m1.1.1.2.1" xref="S2.p19.4.m1.1.1.2.1.cmml">~</mo></mover><mo id="S2.p19.4.m1.1.1.1" xref="S2.p19.4.m1.1.1.1.cmml">≡</mo><mrow id="S2.p19.4.m1.1.1.3" xref="S2.p19.4.m1.1.1.3.cmml"><mi id="S2.p19.4.m1.1.1.3.2" xref="S2.p19.4.m1.1.1.3.2.cmml">H</mi><mo id="S2.p19.4.m1.1.1.3.1" xref="S2.p19.4.m1.1.1.3.1.cmml">/</mo><msub id="S2.p19.4.m1.1.1.3.3" xref="S2.p19.4.m1.1.1.3.3.cmml"><mi id="S2.p19.4.m1.1.1.3.3.2" xref="S2.p19.4.m1.1.1.3.3.2.cmml">H</mi><mn id="S2.p19.4.m1.1.1.3.3.3" xref="S2.p19.4.m1.1.1.3.3.3.cmml">0</mn></msub></mrow></mrow><annotation-xml encoding="MathML-Content" id="S2.p19.4.m1.1b"><apply id="S2.p19.4.m1.1.1.cmml" xref="S2.p19.4.m1.1.1"><equivalent id="S2.p19.4.m1.1.1.1.cmml" xref="S2.p19.4.m1.1.1.1"></equivalent><apply id="S2.p19.4.m1.1.1.2.cmml" xref="S2.p19.4.m1.1.1.2"><ci id="S2.p19.4.m1.1.1.2.1.cmml" xref="S2.p19.4.m1.1.1.2.1">~</ci><ci id="S2.p19.4.m1.1.1.2.2.cmml" xref="S2.p19.4.m1.1.1.2.2">𝐻</ci></apply><apply id="S2.p19.4.m1.1.1.3.cmml" xref="S2.p19.4.m1.1.1.3"><divide id="S2.p19.4.m1.1.1.3.1.cmml" xref="S2.p19.4.m1.1.1.3.1"></divide><ci id="S2.p19.4.m1.1.1.3.2.cmml" xref="S2.p19.4.m1.1.1.3.2">𝐻</ci><apply id="S2.p19.4.m1.1.1.3.3.cmml" xref="S2.p19.4.m1.1.1.3.3"><csymbol cd="ambiguous" id="S2.p19.4.m1.1.1.3.3.1.cmml" xref="S2.p19.4.m1.1.1.3.3">subscript</csymbol><ci id="S2.p19.4.m1.1.1.3.3.2.cmml" xref="S2.p19.4.m1.1.1.3.3.2">𝐻</ci><cn id="S2.p19.4.m1.1.1.3.3.3.cmml" type="integer" xref="S2.p19.4.m1.1.1.3.3.3">0</cn></apply></apply></apply></annotation-xml><annotation encoding="application/x-tex" id="S2.p19.4.m1.1c">\tilde{H}\equiv H/H_{0}</annotation><annotation encoding="application/x-llamapun" id="S2.p19.4.m1.1d">over~ start_ARG italic_H end_ARG ≡ italic_H / italic_H start_POSTSUBSCRIPT 0 end_POSTSUBSCRIPT</annotation></semantics></math> is the is normalized Hubble parameter.</p>
