.1.1.1.1.1.1.2.3.3.cmml">μ</mi></msub></mrow></mrow><mo id="S2.E6.m1.3.3.1.1.1.1.1.1.3" xref="S2.E6.m1.3.3.1.1.1.1.2.cmml">)</mo></mrow></mrow></mrow></mrow><mo id="S2.E6.m1.3.3.1.2" lspace="0.170em" xref="S2.E6.m1.3.3.1.1.cmml">.</mo></mrow><annotation-xml encoding="MathML-Content" id="S2.E6.m1.3b"><apply id="S2.E6.m1.3.3.1.1.cmml" xref="S2.E6.m1.3.3.1"><eq id="S2.E6.m1.3.3.1.1.2.cmml" xref="S2.E6.m1.3.3.1.1.2"></eq><ci id="S2.E6.m1.3.3.1.1.3.cmml" xref="S2.E6.m1.3.3.1.1.3">italic-ϕ</ci><apply id="S2.E6.m1.3.3.1.1.1.cmml" xref="S2.E6.m1.3.3.1.1.1"><times id="S2.E6.m1.3.3.1.1.1.2.cmml" xref="S2.E6.m1.3.3.1.1.1.2"></times><apply id="S2.E6.m1.3.3.1.1.1.3.cmml" xref="S2.E6.m1.3.3.1.1.1.3"><divide id="S2.E6.m1.3.3.1.1.1.3.1.cmml" xref="S2.E6.m1.3.3.1.1.1.3"></divide><cn id="S2.E6.m1.3.3.1.1.1.3.2.cmml" type="integer" xref="S2.E6.m1.3.3.1.1.1.3.2">1</cn><cn id="S2.E6.m1.3.3.1.1.1.3.3.cmml" type="integer" xref="S2.E6.m1.3.3.1.1.1.3.3">2</cn></apply><apply id="S2.E6.m1.3.3.1.1.1.1.2.cmml" xref="S2.E6.m1.3.3.1.1.1.1.1"><ln id="S2.E6.m1.2.2.cmml" xref="S2.E6.m1.2.2"></ln><apply id="S2.E6.m1.3.3.1.1.1.1.1.1.1.cmml" xref="S2.E6.m1.3.3.1.1.1.1.1.1.1"><minus id="S2.E6.m1.3.3.1.1.1.1.1.1.1.1.cmml" xref="S2.E6.m1.3.3.1.1.1.1.1.1.1"></minus><apply id="S2.E6.m1.3.3.1.1.1.1.1.1.1.2.cmml" xref="S2.E6.m1.3.3.1.1.1.1.1.1.1.2"><times id="S2.E6.m1.3.3.1.1.1.1.1.1.1.2.1.cmml" xref="S2.E6.m1.3.3.1.1.1.1.1.1.1.2.1"></times><apply id="S2.E6.m1.3.3.1.1.1.1.1.1.1.2.2.cmml" xref="S2.E6.m1.3.3.1.1.1.1.1.1.1.2.2"><csymbol cd="ambiguous" id="S2.E6.m1.3.3.1.1.1.1.1.1.1.2.2.1.cmml" xref="S2.E6.m1.3.3.1.1.1.1.1.1.1.2.2">superscript</csymbol><ci id="S2.E6.m1.3.3.1.1.1.1.1.1.1.2.2.2.cmml" xref="S2.E6.m1.3.3.1.1.1.1.1.1.1.2.2.2">𝜉</ci><ci id="S2.E6.m1.3.3.1.1.1.1.1.1.1.2.2.3.cmml" xref="S2.E6.m1.3.3.1.1.1.1.1.1.1.2.2.3">𝜇</ci></apply><apply id="S2.E6.m1.3.3.1.1.1.1.1.1.1.2.3.cmml" xref="S2.E6.m1.3.3.1.1.1.1.1.1.1.2.3"><csymbol cd="ambiguous" id="S2.E6.m1.3.3.1.1.1.1.1.1.1.2.3.1.cmml" xref="S2.E6.m1.3.3.1.1.1.1.1.1.1.2.3">subscript</csymbol><ci id="S2.E6.m1.3.3.1.1.1.1.1.1.1.2.3.2.cmml" xref="S2.E6.m1.3.3.1.1.1.1.1.1.1.2.3.2">𝜉</ci><ci id="S2.E6.m1.3.3.1.1.1.1.1.1.1.2.3.3.cmml" xref="S2.E6.m1.3.3.1.1.1.1.1.1.1.2.3.3">𝜇</ci></apply></apply></apply></apply></apply></apply></annotation-xml><annotation encoding="application/x-tex" id="S2.E6.m1.3c">\phi=\frac{1}{2}\ln\left(-\xi^{\mu}\text{$\xi$}_{\mu}\right)\,.</annotation><annotation encoding="application/x-llamapun" id="S2.E6.m1.3d">italic_ϕ = divide start_ARG 1 end_ARG start_ARG 2 end_ARG roman_ln ( - italic_ξ start_POSTSUPERSCRIPT italic_μ end_POSTSUPERSCRIPT italic_ξ start_POSTSUBSCRIPT italic_μ end_POSTSUBSCRIPT ) .</annotation></semantics></math></td>
