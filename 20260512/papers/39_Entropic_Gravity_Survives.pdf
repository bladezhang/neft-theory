<td class="ltx_eqn_cell ltx_align_center"><math alttext="H_{0}=73.04\pm 1.04\,\mathrm{km\ s^{-1}Mpc^{-1}}\,." class="ltx_Math" display="block" id="S3.E66.m1.1"><semantics id="S3.E66.m1.1a"><mrow id="S3.E66.m1.1.1.1" xref="S3.E66.m1.1.1.1.1.cmml"><mrow id="S3.E66.m1.1.1.1.1" xref="S3.E66.m1.1.1.1.1.cmml"><msub id="S3.E66.m1.1.1.1.1.2" xref="S3.E66.m1.1.1.1.1.2.cmml"><mi id="S3.E66.m1.1.1.1.1.2.2" xref="S3.E66.m1.1.1.1.1.2.2.cmml">H</mi><mn id="S3.E66.m1.1.1.1.1.2.3" xref="S3.E66.m1.1.1.1.1.2.3.cmml">0</mn></msub><mo id="S3.E66.m1.1.1.1.1.1" xref="S3.E66.m1.1.1.1.1.1.cmml">=</mo><mrow id="S3.E66.m1.1.1.1.1.3" xref="S3.E66.m1.1.1.1.1.3.cmml"><mn id="S3.E66.m1.1.1.1.1.3.2" xref="S3.E66.m1.1.1.1.1.3.2.cmml">73.04</mn><mo id="S3.E66.m1.1.1.1.1.3.1" xref="S3.E66.m1.1.1.1.1.3.1.cmml">±</mo><mrow id="S3.E66.m1.1.1.1.1.3.3" xref="S3.E66.m1.1.1.1.1.3.3.cmml"><mn id="S3.E66.m1.1.1.1.1.3.3.2" xref="S3.E66.m1.1.1.1.1.3.3.2.cmml">1.04</mn><mo id="S3.E66.m1.1.1.1.1.3.3.1" lspace="0.170em" xref="S3.E66.m1.1.1.1.1.3.3.1.cmml">⁢</mo><mi id="S3.E66.m1.1.1.1.1.3.3.3" xref="S3.E66.m1.1.1.1.1.3.3.3.cmml">km</mi><mo id="S3.E66.m1.1.1.1.1.3.3.1a" lspace="0.500em" xref="S3.E66.m1.1.1.1.1.3.3.1.cmml">⁢</mo><msup id="S3.E66.m1.1.1.1.1.3.3.4" xref="S3.E66.m1.1.1.1.1.3.3.4.cmml"><mi id="S3.E66.m1.1.1.1.1.3.3.4.2" mathvariant="normal" xref="S3.E66.m1.1.1.1.1.3.3.4.2.cmml">s</mi><mrow id="S3.E66.m1.1.1.1.1.3.3.4.3" xref="S3.E66.m1.1.1.1.1.3.3.4.3.cmml"><mo id="S3.E66.m1.1.1.1.1.3.3.4.3a" xref="S3.E66.m1.1.1.1.1.3.3.4.3.cmml">−</mo><mn id="S3.E66.m1.1.1.1.1.3.3.4.3.2" xref="S3.E66.m1.1.1.1.1.3.3.4.3.2.cmml">1</mn></mrow></msup><mo id="S3.E66.m1.1.1.1.1.3.3.1b" xref="S3.E66.m1.1.1.1.1.3.3.1.cmml">⁢</mo><msup id="S3.E66.m1.1.1.1.1.3.3.5" xref="S3.E66.m1.1.1.1.1.3.3.5.cmml"><mi id="S3.E66.m1.1.1.1.1.3.3.5.2" xref="S3.E66.m1.1.1.1.1.3.3.5.2.cmml">Mpc</mi><mrow id="S3.E66.m1.1.1.1.1.3.3.5.3" xref="S3.E66.m1.1.1.1.1.3.3.5.3.cmml"><mo id="S3.E66.m1.1.1.1.1.3.3.5.3a" xref="S3.E66.m1.1.1.1.1.3.3.5.3.cmml">−</mo><mn id="S3.E66.m1.1.1.1.1.3.3.5.3.2" xref="S3.E66.m1.1.1.1.1.3.3.5.3.2.cmml">1</mn></mrow></msup></mrow></mrow></mrow><mo id="S3.E66.m1.1.1.1.2" lspace="0em" xref="S3.E66.m1.1.1.1.1.cmml">.</mo></mrow><annotation-xml encoding="MathML-Content" id="S3.E66.m1.1b"><apply id="S3.E66.m1.1.1.1.1.cmml" xref="S3.E66.m1.1.1.1"><eq id="S3.E66.m1.1.1.1.1.1.cmml" xref="S3.E66.m1.1.1.1.1.1"></eq><apply id="S3.E66.m1.1.1.1.1.2.cmml" xref="S3.E66.m1.1.1.1.1.2"><csymbol cd="ambiguous" id="S3.E66.m1.1.1.1.1.2.1.cmml" xref="S3.E66.m1.1.1.1.1.2">subscript</csymbol><ci id="S3.E66.m1.1.1.1.1.2.2.cmml" xref="S3.E66.m1.1.1.1.1.2.2">𝐻</ci><cn id="S3.E66.m1.1.1.1.1.2.3.cmml" type="integer" xref="S3.E66.m1.1.1.1.1.2.3">0</cn></apply><apply id="S3.E66.m1.1.1.1.1.3.cmml" xref="S3.E66.m1.1.1.1.1.3"><csymbol cd="latexml" id="S3.E66.m1.1.1.1.1.3.1.cmml" xref="S3.E66.m1.1.1.1.1.3.1">plus-or-minus</csymbol><cn id="S3.E66.m1.1.1.1.1.3.2.cmml" type="float" xref="S3.E66.m1.1.1.1.1.3.2">73.04</cn><apply id="S3.E66.m1.1.1.1.1.3.3.cmml" xref="S3.E66.m1.1.1.1.1.3.3"><times id="S3.E66.m1.1.1.1.1.3.3.1.cmml" xref="S3.E66.m1.1.1.1.1.3.3.1"></times><cn id="S3.E66.m1.1.1.1.1.3.3.2.cmml" type="float" xref="S3.E66.m1.1.1.1.1.3.3.2">1.04</cn><ci id="S3.E66.m1.1.1.1.1.3.3.3.cmml" xref="S3.E66.m1.1.1.1.1.3.3.3">km</ci><apply id="S3.E66.m1.1.1.1.1.3.3.4.cmml" xref="S3.E66.m1.1.1.1.1.3.3.4"><csymbol cd="ambiguous" id="S3.E66.m1.1.1.1.1.3.3.4.1.cmml" xref="S3.E66.m1.1.1.1.1.3.3.4">superscript</csymbol><ci id="S3.E66.m1.1.1.1.1.3.3.4.2.cmml" xref="S3.E66.m1.1.1.1.1.3.3.4.2">s</ci><apply id="S3.E66.m1.1.1.1.1.3.3.4.3.cmml" xref="S3.E66.m1.1.1.1.1.3.3.4.3"><minus id="S3.E66.m1.1.1.1.1.3.3.4.3.1.cmml" xref="S3.E66.m1.1.1.1.1.3.3.4.3"></minus><cn id="S3.E66.m1.1.1.1.1.3.3.4.3.2.cmml" type="integer" xref="S3.E66.m1.1.1.1.1.3.3.4.3.2">1</cn></apply></apply><apply id="S3.E66.m1.1.1.1.1.3.3.5.cmml" xref="S3.E66.m1.1.1.1.1.3.3.5"><csymbol cd="ambiguous" id="S3.E66.m1.1.1.1.1.3.3.5.1.cmml" xref="S3.E66.m1.1.1.1.1.3.3.5">supe